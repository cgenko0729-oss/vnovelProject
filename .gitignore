# ============================================
# Unity 项目专用 .gitignore
# 只提交源资产与设置，所有可再生成的目录一律排除
# ============================================

# Unity 生成目录（体积巨大且可完全重新生成）
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]serSettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# 打包输出
*.apk
*.aab
*.unitypackage
*.app

# IDE / 编辑器
/.vs/
/.idea/
/.vscode/
*.csproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# Unity 崩溃报告
sysinfo.txt
crashlytics-build.properties

# 调试截图（本地排错用，不进仓库）
/Assets/DebugScreenShot/
/Assets/DebugScreenShot.meta
